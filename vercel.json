{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/site.webmanifest", "destination": "/public/site.webmanifest" },
    { "source": "/vehicle-data.json", "destination": "/public/vehicle-data.json" },
    { "source": "/favicon.svg", "destination": "/public/favicon.svg" },
    { "source": "/favicon-16x16.png", "destination": "/public/favicon-16x16.png" },
    { "source": "/favicon-32x32.png", "destination": "/public/favicon-32x32.png" },
    { "source": "/favicon-192x192.png", "destination": "/public/favicon-192x192.png" },
    { "source": "/favicon-512x512.png", "destination": "/public/favicon-512x512.png" },
    { "source": "/apple-touch-icon.png", "destination": "/public/apple-touch-icon.png" },
    { "source": "/fonts/:path*", "destination": "/public/fonts/:path*" },
    { "source": "/vehicles/:path*", "destination": "/public/vehicles/:path*" }
  ]
}
